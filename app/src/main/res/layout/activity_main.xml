<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<!--    线性布局，居中对齐-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/textView"
            android:layout_width="286dp"
            android:layout_height="36dp"
            android:text="@string/app_name" />

        <Button
            android:id="@+id/btn_test2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btnTest2" />

        <Button
            android:id="@+id/btn_test1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btnTest1" />

        <Button
            android:id="@+id/btn_aar_service"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_aar_service" />

        <Button
            android:id="@+id/btn_gl_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btnGLTest" />

        <Button
            android:id="@+id/btn_opengl_activity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btnGLActivity" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>